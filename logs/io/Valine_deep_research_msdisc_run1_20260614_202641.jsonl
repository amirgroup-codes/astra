\", \"rxn_004\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Shock plus concentrated surface cyanide to valine\",\n      \"description\": \"Shock-generated precursor pools are concentrated on mineral-rich surfaces and then enter the Strecker-hydrolysis path.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_012\", \"rxn_003\", \"rxn_004\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Ice photochemical precursor plus concentrated surface cyanide to valine\",\n      \"description\": \"Mixed-ice photochemical precursor residue is funneled through concentrated surface Strecker chemistry to valine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_012\", \"rxn_003\", \"rxn_004\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Hydrothermal-biochemical recycle route to valine\",\n      \"description\": \"A network-cycle route in which hydrothermal degradation/recycling reconnects valine-derived carbon to pyruvate context, then to 2-ketoisovalerate and back to valine through \u03b1-ketoacid amination.\",\n      \"reaction_sequence\": [\"rxn_011\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_010\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_006\", \"mol_007\", \"mol_008\", \"mol_010\", \"mol_011\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_001\", \"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [\"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_004\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_009\