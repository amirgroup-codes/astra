_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface reduction of CO2 by H2 produces formate as a one-carbon reduced intermediate.\",\n      \"reasoning\": \"Used as a literature-consistent hydrothermal feedstock step to connect vent chemistry to surface carbonyl chemistry; such CO2-to-formate reduction on Fe-S minerals is consistent with hydrothermal prebiotic carbon fixation frameworks summarized in Aubrey et al. 2009 and Barge et al. 2019. This step is not threonine-specific but is necessary to connect the network.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal Fischer-Tropsch-type generation of formaldehyde and acetaldehyde\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_004\", \"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/elemental iron\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal/subseafloor setting; carbonyls exported to cooler surface environments\"\n      },\n      \"mechanism\": \"Hydrogenation and partial reduction of carbon oxides on iron-rich mineral surfaces yields small aldehydes.\",\n      \"reasoning\": \"Included as an upstream source of acetaldehyde and formaldehyde needed for the aldol, Strecker, and sugar-derived branches. The environmental plausibility of aldehyde generation and fate under primordial conditions is aligned with the retained aldehyde context in the Life 2023 review and hydrothermal carbon-fixation framing in Aubrey et al. 2009.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Surface photochemical generation of HCN and formamide from carbonyl-rich precursor pool\",\n      \"inputs\": [\"mol_004\", \"mol_008\"],\n      \"outputs\": [\"mol_006\", \"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 photocatalytic surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated shallow pools, anoxic atmosphere\"\n      },\n      \"mechanism\": \"UV-driven photochemistry of simple C/N precursors in surface waters produces cyanide-bearing species and formamide-like C-N intermediates.\",\n      \"reasoning\": \"This is a connective step to supply HCN/formamide into the cyanide network. It is grounded in the strong role of UV and discharge chemistry in precursor production discussed across Miller-Urey and prebiotic photochemistry literature, including Ring et al. 1972, Johnson et al. 2008, Bada 2013, and the precursor context summarized in the research report. It is partly speculative as a network-bridging surface implementation.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"HCN oligomerization to aminomalononitrile\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite concentration surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"HCN-rich evaporative ponds, drying-wetting concentration cycles\"\n      },\n      \"mechanism\": \"Concentration and oligomerization of HCN yields aminomalononitrile as a nitrile-rich intermediate.\",\n      \"reasoning\": \"AMN is explicitly identified in the deep research report as a central precursor in the strongest direct threonine-positive route. HCN-rich concentration settings are part of the retained environmental interpretation, and clay/mineral concentration is used here as a plausible surface aid. Direct threonine relevance comes from Thanassi 1975 via the AMN branch.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Formose and borate-stabilized sugar formation to threose\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic pools with wet-dry cycling; borate stabilization of tetroses\"\n      },\n      \"mechanism\": \"Aldol/formose chemistry of formaldehyde under surface concentration conditions yields tetroses including threose, stabilized by borate.\",\n      \"reasoning\": \"The sugar-derived threonine branch in the retained evidence depends on the availability of threose or related tetroses. The 2012 JACS paper supports prebiotic generation of erythrose and threose; borate-assisted stabilization is contextual and consistent with the report's sugar-availability framing. This is precursor-level support rather than a direct threonine demonstration.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Strecker formation of threonine aminonitrile from 2-hydroxybutanal\",\n      \"inputs\": [\"mol_010\", \"mol_008\", \"mol_007\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"not reported / not recovered\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite concentration surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"cyanide-bearing surface waters; pH-sensitive imine/aminonitrile equilibria; hydrolysis required downstream\"\n      },\n      \"mechanism\": \"2-Hydroxybutanal forms an imine with ammonia followed by cyanide addition to yield the aminonitrile precursor of threonine/allothreonine.\",\n      \"reasoning\": \"This directly follows the retained Strecker/2-hydroxybutanal route logic summarized from Magrino et al. 2021 and the report's R1 narrative. The report explicitly states this route is chemically plausible but lacks a directly retrieved threonine-specific primary experiment, so this node is retained as a supported hypothesis rather than a fully demonstrated route.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Aminomalononitrile plus acetaldehyde electrophile route to threonine/allothreonine after hydrolysis\",\n      \"inputs\": [\"mol_009\", \"mol_005\"],\n      \"outputs\": [\"mol_014\", \"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"mild conditions reported qualitatively\",\n        \"pressure\": \"not reported / not recovered\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous reaction with subsequent hydrolysis; HCN-rich concentration setting plausible\"\n      },\n      \"mechanism\": \"AMN reacts with an electrophilic carbonyl partner, then hydrolysis converts nitrile-rich intermediates to amino acid products including threonine and allothreonine.\",\n      \"reasoning\": \"This is the strongest direct threonine-positive route in the retained evidence. Thanassi 1975 reportedly identified and quantitated DL-threonine and allo-threonine from AMN reactions with electrophiles, though exact electrophiles, yields, and detailed conditions were not recoverable in the workspace. Acetaldehyde is used here as a connected electrophilic carbonyl partner because the report identifies acetaldehyde as a central carbonyl precursor and requires electrophile participation in the AMN route.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrolysis of threonine aminonitrile to threonine and allothreonine\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_014\", \"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"not reported / not recovered\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous hydrolysis workup; racemic/diastereomeric mixture expected\"\n      },\n      \"mechanism\": \"Nitrile hydrolysis of the Strecker aminonitrile yields beta-hydroxy amino acids as threonine and allothreonine.\",\n      \"reasoning\": \"This is the standard completion step for the retained Strecker 2-hydroxybutanal branch and matches the report's R1 description: imine/aminonitrile intermediate followed by hydrolysis gives DL-threonine plus DL-allothreonine. Support is mechanistic from Magrino et al. 2021 and route-specific from the report, but still classified as under-demonstrated for this exact substrate set.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Glycine plus acetaldehyde aldol/beta-hydroxy route to threonine/allothreonine\",\n      \"inputs\": [\"mol_012\", \"mol_005\"],\n      \"outputs\": [\"mol_014\", \"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"not reported / not recovered\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"shallow ponds or wet-dry shorelines; pH likely important but not extracted\"\n      },\n      \"mechanism\": \"Carbon-carbon bond formation between glycine-derived nucleophilic species and acetaldehyde gives beta-hydroxy amino acid products related to threonine.\",\n      \"reasoning\": \"This follows the retained aldol/beta-hydroxy branch from Subbaraman et al. 1972 route context and the report's R4 narrative. The evidence is explicitly weak for threonine-specific prebiotic demonstration, but the route is historically proposed and chemically plausible. Included as a necessary literature-based alternative path.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Sugar-derived amination/redox conversion of threose to threonine\",\n      \"inputs\": [\"mol_013\", \"mol_008\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"not reported / not recovered\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"surface pool carryover into prebiotic pools; amination/redox chemistry inferred\"\n      },\n      \"mechanism\": \"A threose-derived beta-hydroxy carbon framework undergoes amination and redox adjustment to access threonine.\",\n      \"reasoning\": \"This encodes the retained sugar-derived beta-hydroxy route. The report states threose availability is supported by the 2012 JACS tetrose literature, but no direct threonine-from-threose experiment was recovered; therefore this reaction is explicitly speculative but necessary to represent the literature-recognized branch.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Spark-discharge generation of threonine/allothreonine precursor pool with hydrolysis to products\",\n      \"inputs\": [\"mol_005\", \"mol_008\", \"mol_007\"]