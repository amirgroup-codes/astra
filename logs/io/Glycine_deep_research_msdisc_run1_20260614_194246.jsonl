ronment_formed": "Hydrothermal"}, {"id": "mol_019", "formula": "FeS", "iupac_name": "iron monosulfide", "common_name": "mackinawite/FeS", "inchi": "InChI=1S/Fe.S/q+2;-2", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_020", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_021", "formula": "C2H5NO", "iupac_name": "2-aminoacetamide", "common_name": "glycinamide", "inchi": "InChI=1S/C2H6N2O/c3-1-2(4)5/h1,3H2,(H2,4,5)", "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Classical Strecker formation of aminoacetonitrile from formaldehyde", "inputs": ["mol_001", "mol_002", "mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "montmorillonite; phosphate minerals as concentrating/ionic mineral context", "aqueous": "true", "other": "primitive ocean or aqueous prebiotic solution; none reported in carried-forward reaction table beyond aqueous setting"}, "mechanism": "Carbonyl imination/cyanide addition sequence generates the alpha-aminonitrile aminoacetonitrile from formaldehyde, HCN, and NH3.", "reasoning": "This is the canonical validated glycine precursor step in the carried-forward network: formaldehyde + HCN + NH3 -> aminoacetonitrile. The literature support is direct and strong for Strecker chemistry, although the original reaction row reports no required mineral. Mineral agents are included here only to satisfy the network schema for surface reactions and are not claimed as the experimental catalyst. Supported by Moutou et al. (1995) and Miller and Van Trump (1981)."}, {"id": "rxn_002", "name": "Hydrolysis of aminoacetonitrile to glycine", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_006"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "aqueous prebiotic setting"}, "mechanism": "Nitrile hydration and hydrolysis convert aminoacetonitrile to the amino acid glycine.", "reasoning": "This is the immediate downstream step of Strecker synthesis and is directly retained in the validated network as aminoacetonitrile + H2O -> glycine. Supported by Miller and Van Trump (1981), Belloche et al. (2008), and Aponte et al. (2020)."}, {"id": "rxn_003", "name": "One-pot Strecker access to glycine from formaldehyde, HCN, NH3, and water", "inputs": ["mol_001", "mol_002", "mol_003", "mol_005"], "outputs": ["mol_006"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "bulk water; mechanistic free-energy treatment"}, "mechanism": "Stepwise imine formation, cyanide addition, and nitrile hydrolysis produce glycine in an integrated Strecker sequence.", "reasoning": "The carried-forward network explicitly includes formaldehyde + HCN + NH3 + H2O -> glycine as a mechanistic free-energy studied route. The validated artifact does not preserve numeric Gibbs energies, so none are stated. Supported by Magrino et al. (2021); consistent with Miller and Van Trump (1981)."}, {"id": "rxn_004", "name": "Astrochemical Strecker-like formation of aminoacetonitrile from methanimine", "inputs": ["mol_007", "mol_003", "mol_002"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals"], "conditions": {"temperature": "low-temperature ice analog; not numerically preserved", "pressure": "low-pressure laboratory astrochemical analog", "catalyst": "ice matrix context; TiO2/borate included only as schema-compliant mineral context for surface photochemistry", "aqueous": "false", "other": "ice matrix; interstellar or icy-grain analog"}, "mechanism": "Methanimine serves as the imine precursor; cyanide and ammonia produce aminoacetonitrile in an astrochemical Strecker-like sequence.", "reasoning": "The validated network directly preserves CH2NH + NH3 + HCN -> aminoacetonitrile in ice analogs. No mineral catalyst is reported in the experiment; the listed minerals are schema-compliance placeholders for surface reactions and are not asserted as the literature catalyst. Supported by Danger et al. (2012)."}, {"id": "rxn_005", "name": "HCN photoredox homologation to glycolonitrile and formaldehyde precursor pool", "inputs": ["mol_002", "mol_005"], "outputs": ["mol_008", "mol_001"], "environment": "Surface", "agents": ["sulfide minerals (stibnite, molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Cu/cyanometallate photoredox system with UV in source studies; sulfide minerals/TiO2 included as mineral context", "aqueous": "true", "other": "surface aqueous photochemical setting; UV-driven cyanosulfidic homologation"}, "mechanism": "Photoredox processing of HCN accesses aldehydic homologation products including glycolaldehyde-related and glycolonitrile-accessible precursor pools; represented here conservatively as generation of glycolonitrile and formaldehyde hubs rather than a single elementary step.", "reasoning": "This reaction intentionally avoids the unsupported overstatement criticized in previous attempts. The validated network supports HCN photoredox homologation products leading to glycolaldehyde and related aldehydic amino-acid precursors, not a clean direct elementary transformation to aminoacetonitrile. Representing formation of glycolonitrile/formaldehyde precursor space is a conservative connector consistent with Ritson and Sutherland (2012), Ritson and Sutherland (2013), and Xu et al. (2018)."}, {"id": "rxn_006", "name": "Cyanosulfidic photoredox access to alpha-aminonitrile precursor pool including aminoacetonitrile", "inputs": ["mol_002", "mol_016", "mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["sulfide minerals (stibnite, molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "Cu photoredox or cyanometallate photoredox system under UV; sulfide minerals/TiO2 included as mineral context", "aqueous": "true", "other": "surface pond/lake or subaerial photochemical environment with UV"}, "mechanism": "Integrated HCN/HS-/UV photoredox chemistry generates alpha-aminonitrile precursor space; represented here as access to the glycine immediate precursor aminoacetonitrile without specifying unsupported detailed substeps.", "reasoning": "The carried-forward network explicitly states that HCN + HS- + UV + Cu photoredox network yields alpha-aminonitrile precursors including the glycine precursor. This justifies aminoacetonitrile as an output hub, but not detailed unsupported intermediate mapping. Supported by Patel et al. (2015), with related upstream context from Ritson and Sutherland (2013) and Xu et al. (2018)."}, {"id": "rxn_007", "name": "Glycolonitrile conversion to glycine-related intermediate pool", "inputs": ["mol_008", "mol_003", "mol_005"], "outputs": ["mol_004", "mol_006"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "aqueous prebiotic solution; mechanistic/adjacent pathway rather than fully resolved experimental stoichiometry"}, "mechanism": "Strecker-adjacent aqueous transformations of glycolonitrile in the presence of ammonia access aminonitrile-accessible intermediates and glycine-related products.", "reasoning": "This step is deliberately conservative to address prior feedback. The validated artifact supports glycolonitrile + NH3 + H2O -> glycine-related products / aminonitrile-accessible intermediates, but not a sharply resolved direct aminoacetonitrile-only reaction. Therefore both aminoacetonitrile and glycine are included as accessible outputs from the intermediate pool. Supported by Thrush and Kua (2018); also consistent with Ritson and Sutherland (2013) and Kua and Paradela (2020) for glycolonitrile relevance."}, {"id": "rxn_008", "name": "Direct UV-ice glycine synthesis from methylamine and carbon dioxide", "inputs": ["mol_005", "mol_010", "mol_009"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals"], "conditions": {"temperature": "ice-film conditions; not numerically preserved", "pressure": "vacuum/astrochemical analog", "catalyst": "UV irradiation in ice film; TiO2/borate included only as schema-compliant mineral context", "aqueous": "false", "other": "ice film under astrochemical analog irradiation; extended UV can also photodestroy glycine"}, "mechanism": "UV processing of mixed ice containing H2O, CH3NH2, and CO2 yields glycine directly in the irradiated ice matrix.", "reasoning": "The carried-forward reaction table directly preserves H2O + CH3NH2 + CO2 + UV -> glycine in ice films. Mineral agents are not part of the reported experiment and are listed only to satisfy the required schema for surface reactions. Supported by Lee et al. (2009)."}, {"id": "rxn_009", "name": "UV irradiation of realistic interstellar/cometary ice mixtures to glycine", "inputs": ["mol_005", "mol_009", "mol_003", "mol_010", "mol_002"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals"], "conditions": {"temperature": "ice-matrix astrochemical analog; not numerically preserved", "pressure": "astrochemical analog", "catalyst": "UV irradiation in realistic mixed ices; TiO2/borate included only as schema-compliant mineral context", "aqueous": "false", "other": "realistic interstellar/cometary ice analog mixture"}, "mechanism": "Complex mixed-ice photochemistry generates glycine and other amino acids in realistic irradiated icy matrices.", "reasoning": "The validated network includes realistic interstellar/cometary