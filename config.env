# Model Provider Selection: "claude", "gpt41", "gpt5.4_openai", "gpt5.4_agent_azure"
MODEL_PROVIDER=gpt5.4_agent_azure

# Anthropic Claude Configuration
ANTHROPIC_API_KEY=YOUR_KEY
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=32768
CLAUDE_THINKING_BUDGET=10000
CLAUDE_ENABLE_THINKING=true

# Azure OpenAI Configuration (GPT-4o)
AZURE_OPENAI_ENDPOINT=YOUR_KEY
AZURE_OPENAI_API_KEY=YOUR_KEY
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_DEPLOYMENT_NAME_MINI=gpt-4o-mini

# Azure GPT-4.1 Configuration
AZURE_GPT41_ENDPOINT=YOUR_KEY
AZURE_GPT41_API_KEY=YOUR_KEY
AZURE_GPT41_API_VERSION=2025-01-01-preview
AZURE_GPT41_DEPLOYMENT_NAME=gpt-4.1

# Azure OpenAI Deep Research Configuration
AZURE_DEEP_RESEARCH_ENDPOINT=YOUR_KEY
AZURE_DEEP_RESEARCH_API_KEY=YOUR_KEY
AZURE_DEEP_RESEARCH_MODEL=o3-deep-research

# Azure OpenAI Embedding Configuration
AZURE_EMBEDDING_ENDPOINT=YOUR_KEY
AZURE_EMBEDDING_API_KEY=YOUR_KEY
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_EMBEDDING_MODEL=text-embedding-3-large
AZURE_EMBEDDING_API_VERSION=2024-12-01-preview

# Direct OpenAI GPT-5.4 Configuration
OPENAI_DIRECT_API_KEY=YOUR_KEY
OPENAI_DIRECT_MODEL=gpt-5.4

# Azure AI Agent (GPT-5.4 Agent) Configuration
AZURE_AGENT_PROJECT_ENDPOINT=YOUR_KEY
AZURE_AGENT_NAME=testAgent
AZURE_AGENT_VERSION=1

# Google Gemini Configuration
GOOGLE_API_KEY=YOUR_KEY